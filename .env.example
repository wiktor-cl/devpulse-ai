# ─── DevPulse AI — Environment Variables ───────────────────────────────────
# Copy to .env and fill in your values. Never commit .env to git.

# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=devpulse
DB_USERNAME=devpulse
DB_PASSWORD=devpulse123

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=devpulse-super-secret-key-change-in-production-must-be-at-least-256-bits
JWT_EXPIRATION=86400000        # 24h in ms
JWT_REFRESH_EXPIRATION=604800000  # 7d in ms

# ── OpenAI ───────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here
OPENAI_MODEL=gpt-4o-mini

# ── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ── Server ───────────────────────────────────────────────────────────────────
SERVER_PORT=8080
LOG_LEVEL=INFO

# ── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_BASE_URL=http://localhost:8080/api
